# Database (Supabase)
# Pooled URL (PgBouncer) for runtime
DATABASE_URL="postgres://postgres.your-project:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
# Direct URL for Prisma CLI commands (migrations, db push)
DIRECT_URL="postgres://postgres.your-project:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Auth (NextAuth v5)
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# File uploads (Vercel Blob)
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"
